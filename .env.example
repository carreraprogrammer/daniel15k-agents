# Brain — Variables de entorno requeridas
# Copia este archivo a .env y llena los valores

# LLM provider
LLM_PROVIDER=kimi
LLM_MODEL=kimi-k2.5

# Anthropic (legacy-compatible)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-proj-...
# Alias legacy aceptado:
OPEN_AI_API_KEY=

# Kimi / Moonshot
KIMI_API_KEY=sk-...
# Alias legacy aceptado:
KIMI_AI_API_KEY=
# Override opcional:
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Rails API
DANIEL15K_API_URL=https://daniel15k-api-production.up.railway.app
DANIEL15K_API_TOKEN=          # JWT de larga duración (crear con rails console)

# Telegram
TELEGRAM_BOT_TOKEN=           # Del BotFather
TELEGRAM_CHAT_ID=             # Tu chat_id personal

# Gmail (para el agente nocturno)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=           # App password de Google, no la contraseña real
